{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u6b22\u8fce\u6765\u5230\u6211\u7684\u7f51\u7ad9\uff01","text":"<p>\u8fd9\u662f\u4f7f\u7528 MkDocs \u548c Material \u4e3b\u9898\u6784\u5efa\u7684\u9759\u6001\u7f51\u7ad9\u3002</p> <p>Si</p> <p></p>"},{"location":"about/","title":"\u5173\u4e8e\u6211","text":"<ul> <li> <p>\u6d77\u5357\u5927\u5b66\u7535\u5b50\u79d1\u5b66\u4e0e\u6280\u672f\u4e13\u4e1a\u672c\u79d1\u751f 2024.12 - \u81f3\u4eca</p> </li> <li> <p>\u8dd1\u8005</p> </li> </ul>"},{"location":"ohush-privacy/","title":"\u9690\u79c1\u653f\u7b56","text":"<p>Ohush \u662f\u7531 \u80e1\u6d4e\uff08\u4ee5\u4e0b\u7b80\u79f0\"\u6211\u4eec\"\uff09\u4e3a\u60a8\u63d0\u4f9b\u7684\u767d\u566a\u97f3\u5e94\u7528\u3002\u672c\u9690\u79c1\u58f0\u660e\u7531\u6211\u4eec\u4e3a\u5904\u7406\u60a8\u7684\u4e2a\u4eba\u4fe1\u606f\u800c\u5236\u5b9a\u3002\u6211\u4eec\u975e\u5e38\u91cd\u89c6\u60a8\u7684\u4e2a\u4eba\u4fe1\u606f\u548c\u9690\u79c1\u4fdd\u62a4\uff0c\u5c06\u4f1a\u6309\u7167\u6cd5\u5f8b\u8981\u6c42\u548c\u4e1a\u754c\u6210\u719f\u7684\u5b89\u5168\u6807\u51c6\uff0c\u4e3a\u60a8\u7684\u4e2a\u4eba\u4fe1\u606f\u63d0\u4f9b\u76f8\u5e94\u7684\u5b89\u5168\u4fdd\u62a4\u63aa\u65bd\u3002</p>"},{"location":"ohush-privacy/#_2","title":"\u4e00\u3001\u6211\u4eec\u6536\u96c6\u7684\u4fe1\u606f","text":"<p>Ohush \u662f\u4e00\u6b3e\u7eaf\u79bb\u7ebf\u5e94\u7528\uff0c\u6211\u4eec\u4e0d\u4f1a\u6536\u96c6\u3001\u5b58\u50a8\u6216\u4e0a\u4f20\u60a8\u7684\u4efb\u4f55\u4e2a\u4eba\u4fe1\u606f\uff0c\u5305\u62ec\u4f46\u4e0d\u9650\u4e8e\u59d3\u540d\u3001\u624b\u673a\u53f7\u3001\u4f4d\u7f6e\u4fe1\u606f\u3001\u8bbe\u5907\u4fe1\u606f\u3001\u4f7f\u7528\u8bb0\u5f55\u7b49\u3002\u6240\u6709\u97f3\u9891\u64ad\u653e\u5747\u5728\u672c\u8bbe\u5907\u672c\u5730\u5b8c\u6210\u3002</p>"},{"location":"ohush-privacy/#_3","title":"\u4e8c\u3001\u6743\u9650\u4f7f\u7528\u8bf4\u660e","text":"<ul> <li>\u540e\u53f0\u8fd0\u884c\u6743\u9650\uff1a\u7528\u4e8e\u5728\u60a8\u9000\u51fa\u5e94\u7528\u6216\u9501\u5c4f\u540e\u7ee7\u7eed\u64ad\u653e\u767d\u566a\u97f3\uff0c\u4fdd\u969c\u52a9\u7720\u4f53\u9a8c\u3002\u8be5\u6743\u9650\u4ec5\u5728\u60a8\u4e3b\u52a8\u542f\u52a8\u64ad\u653e\u65f6\u542f\u7528\uff0c\u505c\u6b62\u64ad\u653e\u540e\u81ea\u52a8\u91ca\u653e\u3002</li> </ul>"},{"location":"ohush-privacy/#_4","title":"\u4e09\u3001\u7b2c\u4e09\u65b9\u670d\u52a1","text":"<p>\u672c\u5e94\u7528\u4e0d\u63a5\u5165\u4efb\u4f55\u7b2c\u4e09\u65b9 SDK\u3001\u5e7f\u544a\u670d\u52a1\u6216\u6570\u636e\u5206\u6790\u5de5\u5177\u3002</p>"},{"location":"ohush-privacy/#_5","title":"\u56db\u3001\u4fe1\u606f\u5b58\u50a8\u4e0e\u5b89\u5168","text":"<p>\u60a8\u7684\u8bbe\u7f6e\u504f\u597d\uff08\u5982\u5b9a\u65f6\u5668\u65f6\u957f\uff09\u4ec5\u5b58\u50a8\u5728\u8bbe\u5907\u672c\u5730\uff0c\u4e0d\u4f1a\u4e0a\u4f20\u81f3\u4efb\u4f55\u670d\u52a1\u5668\u3002\u6211\u4eec\u4e0d\u4f1a\u4e5f\u65e0\u6cd5\u8bbf\u95ee\u60a8\u7684\u4efb\u4f55\u6570\u636e\u3002</p>"},{"location":"ohush-privacy/#_6","title":"\u4e94\u3001\u8054\u7cfb\u6211\u4eec","text":"<p>\u5982\u5bf9\u672c\u9690\u79c1\u653f\u7b56\u6709\u4efb\u4f55\u7591\u95ee\uff0c\u8bf7\u8054\u7cfb\uff1aji_hu@foxmail.com</p>"},{"location":"ohush-privacy/#_7","title":"\u516d\u3001\u66f4\u65b0\u8bf4\u660e","text":"<p>\u672c\u9690\u79c1\u653f\u7b56\u53ef\u80fd\u9002\u65f6\u66f4\u65b0\uff0c\u66f4\u65b0\u540e\u5c06\u5728\u5e94\u7528\u5185\u901a\u77e5\u3002</p> <p>\u751f\u6548\u65e5\u671f\uff1a2026 \u5e74 7 \u6708 7 \u65e5</p>"},{"location":"extract/End%20of%20the%20World%20and%20Hard-Boiled%20Wonderland/","title":"\u4e16\u754c\u5c3d\u5934\u4e0e\u51b7\u9177\u4ed9\u5883\u6458\u5f55","text":"<p>\u592a\u9633\u4e3a\u4ec0\u4e48\u8fd8\u91d1\u5149\u95ea\u95ea\uff1f \u9e1f\u513f\u4e3a\u4ec0\u4e48\u8fd8\u5531\u4e2a\u6ca1\u5b8c\uff1f \u96be\u9053\u4ed6\u4eec\u4e0d\u77e5\u9053\u4e48\uff0c \u4e16\u754c\u5df2\u7ecf\u8d70\u5230\u5c3d\u5934\u3002 </p> <p>\u2014\"THE END OF THE WORLD\"</p>"}]}