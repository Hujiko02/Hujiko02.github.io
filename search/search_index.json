{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u6b22\u8fce\u6765\u5230\u6211\u7684\u7f51\u7ad9\uff01","text":"<p>\u8fd9\u662f\u4f7f\u7528 MkDocs \u548c Material \u4e3b\u9898\u6784\u5efa\u7684\u9759\u6001\u7f51\u7ad9\u3002</p> <p></p>"},{"location":"about/","title":"\u5173\u4e8e\u6211","text":"<ul> <li> <p>\u6d77\u5357\u5927\u5b66\u7535\u5b50\u79d1\u5b66\u4e0e\u6280\u672f\u4e13\u4e1a\u672c\u79d1\u751f 2024.12 - \u81f3\u4eca</p> </li> <li> <p>\u8dd1\u8005</p> </li> </ul>"},{"location":"ohush-privacy/","title":"\u9690\u79c1\u653f\u7b56","text":""},{"location":"ohush-privacy/#ohush","title":"\u5173\u4e8eOhush\u4e0e\u9690\u79c1\u7684\u58f0\u660e","text":"<p>Ohush \u662f\u7531\u80e1\u6d4e\uff08\u4ee5\u4e0b\u7b80\u79f0\"\u6211\u4eec\"\uff09\u4e3a\u60a8\u63d0\u4f9b\u7684\u767d\u566a\u97f3\u64ad\u653e\u5e94\u7528\u3002\u6211\u4eec\u975e\u5e38\u91cd\u89c6\u60a8\u7684\u4e2a\u4eba\u4fe1\u606f\u548c\u9690\u79c1\u4fdd\u62a4\u3002</p>"},{"location":"ohush-privacy/#1","title":"1. \u6211\u4eec\u5982\u4f55\u6536\u96c6\u548c\u4f7f\u7528\u60a8\u7684\u4e2a\u4eba\u4fe1\u606f","text":"<p>Ohush \u662f\u4e00\u6b3e\u7eaf\u672c\u5730\u79bb\u7ebf\u5e94\u7528\u3002\u6211\u4eec\u4e0d\u6536\u96c6\u3001\u4e0d\u5b58\u50a8\u3001\u4e0d\u4e0a\u4f20\u60a8\u7684\u4efb\u4f55\u4e2a\u4eba\u4fe1\u606f\uff08\u5305\u62ec\u4f46\u4e0d\u9650\u4e8e\u59d3\u540d\u3001\u624b\u673a\u53f7\u3001\u4f4d\u7f6e\u4fe1\u606f\u3001\u8bbe\u5907\u6807\u8bc6\u7b26\u3001\u4f7f\u7528\u8bb0\u5f55\u7b49\uff09\u3002</p>"},{"location":"ohush-privacy/#2","title":"2. \u6211\u4eec\u5982\u4f55\u4f7f\u7528\u60a8\u7684\u4e2a\u4eba\u4fe1\u606f","text":"<p>\u4e0d\u9002\u7528\u3002 \u672c\u5e94\u7528\u5728\u4e3a\u60a8\u63d0\u4f9b\u767d\u566a\u97f3\u64ad\u653e\u529f\u80fd\u7684\u8fc7\u7a0b\u4e2d\uff0c\u65e0\u9700\u5904\u7406\u4efb\u4f55\u4e2a\u4eba\u4fe1\u606f\u3002\u60a8\u7684\u8bbe\u7f6e\u504f\u597d\uff08\u5982\u5b9a\u65f6\u5668\u65f6\u957f\uff09\u4ec5\u4fdd\u5b58\u5728\u60a8\u7684\u8bbe\u5907\u672c\u5730\uff0c\u6211\u4eec\u4e0d\u4f1a\u4e5f\u65e0\u6cd5\u8bbf\u95ee\u8fd9\u4e9b\u6570\u636e\u3002</p>"},{"location":"ohush-privacy/#3","title":"3. \u6743\u9650\u4f7f\u7528\u8bf4\u660e","text":"<p>\u4e3a\u5b9e\u73b0\u5e94\u7528\u529f\u80fd\uff0c\u5728\u83b7\u53d6\u60a8\u7684\u540c\u610f\u540e\uff0c\u6211\u4eec\u9700\u8981\u5728\u540e\u53f0\u4fdd\u6301\u97f3\u9891\u670d\u52a1\u8fd0\u884c\uff0c\u4ee5\u652f\u6301\u9501\u5c4f\u6216\u5207\u6362\u5e94\u7528\u540e\u7ee7\u7eed\u64ad\u653e\u767d\u566a\u97f3\u3002\u8be5\u6743\u9650\u4ec5\u7528\u4e8e\u97f3\u9891\u64ad\u653e\uff0c\u4e0d\u4f1a\u7528\u4e8e\u6536\u96c6\u4efb\u4f55\u4fe1\u606f\u3002\u505c\u6b62\u64ad\u653e\u540e\u8be5\u670d\u52a1\u81ea\u52a8\u91ca\u653e\u3002</p>"},{"location":"ohush-privacy/#4","title":"4. \u7ba1\u7406\u60a8\u7684\u4e2a\u4eba\u4fe1\u606f","text":"<p>\u5982\u60a8\u5bf9\u672c\u5e94\u7528\u5904\u7406\u4e2a\u4eba\u4fe1\u606f\u7684\u60c5\u51b5\u5b58\u5728\u4efb\u4f55\u7591\u95ee\u3001\u610f\u89c1\u6216\u5efa\u8bae\uff0c\u53ef\u901a\u8fc7\u672c\u58f0\u660e\u4e2d\"\u5982\u4f55\u8054\u7cfb\u6211\u4eec\"\u7ae0\u8282\u6240\u8ff0\u65b9\u5f0f\u4e0e\u6211\u4eec\u53d6\u5f97\u8054\u7cfb\u3002</p>"},{"location":"ohush-privacy/#5","title":"5. \u4fe1\u606f\u5b58\u50a8\u5730\u70b9\u53ca\u671f\u9650","text":"<p>5.1 \u6240\u6709\u6570\u636e\uff08\u5305\u62ec\u60a8\u7684\u8bbe\u7f6e\u504f\u597d\uff09\u4ec5\u5b58\u50a8\u4e8e\u60a8\u7684\u8bbe\u5907\u672c\u5730\uff0c\u6211\u4eec\u4e0d\u4f1a\u5c06\u4efb\u4f55\u4fe1\u606f\u4e0a\u4f20\u81f3\u670d\u52a1\u5668\u3002</p> <p>5.2 \u6211\u4eec\u627f\u8bfa\uff0c\u9664\u6cd5\u5f8b\u6cd5\u89c4\u53e6\u6709\u89c4\u5b9a\u5916\uff0c\u5bf9\u60a8\u7684\u4fe1\u606f\u7684\u4fdd\u5b58\u671f\u9650\u4e3a\u5b9e\u73b0\u5904\u7406\u76ee\u7684\u6240\u5fc5\u8981\u7684\u6700\u77ed\u65f6\u95f4\u3002</p>"},{"location":"ohush-privacy/#6","title":"6. \u5982\u4f55\u8054\u7cfb\u6211\u4eec","text":"<p>\u90ae\u7bb1\uff1aji_hu@foxmail.com</p> <p>\u5982\u679c\u60a8\u5bf9\u6211\u4eec\u7684\u56de\u590d\u4e0d\u6ee1\u610f\uff0c\u7279\u522b\u662f\u5f53\u60a8\u8ba4\u4e3a\u4e2a\u4eba\u4fe1\u606f\u5904\u7406\u884c\u4e3a\u635f\u5bb3\u4e86\u60a8\u7684\u5408\u6cd5\u6743\u76ca\u65f6\uff0c\u60a8\u8fd8\u53ef\u4ee5\u901a\u8fc7\u5411\u6709\u7ba1\u8f96\u6743\u7684\u4eba\u6c11\u6cd5\u9662\u63d0\u8d77\u8bc9\u8bbc\u7b49\u5916\u90e8\u9014\u5f84\u8fdb\u884c\u89e3\u51b3\u3002</p> <p>\u751f\u6548\u65e5\u671f\uff1a2026\u5e747\u67087\u65e5</p>"},{"location":"extract/End%20of%20the%20World%20and%20Hard-Boiled%20Wonderland/","title":"\u4e16\u754c\u5c3d\u5934\u4e0e\u51b7\u9177\u4ed9\u5883\u6458\u5f55","text":"<p>\u592a\u9633\u4e3a\u4ec0\u4e48\u8fd8\u91d1\u5149\u95ea\u95ea\uff1f \u9e1f\u513f\u4e3a\u4ec0\u4e48\u8fd8\u5531\u4e2a\u6ca1\u5b8c\uff1f \u96be\u9053\u4ed6\u4eec\u4e0d\u77e5\u9053\u4e48\uff0c \u4e16\u754c\u5df2\u7ecf\u8d70\u5230\u5c3d\u5934\u3002 </p> <p>\u2014\"THE END OF THE WORLD\"</p>"}]}